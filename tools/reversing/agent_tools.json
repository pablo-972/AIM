{
    "function": {
        "description": "Return metadata and instructions for one function.",
        "parameters": {
            "function": {
                "description": "Function name or address.",
                "type": "string",
                "required": true
            }
        }
    },
    "disassembly": {
        "description": "Return bounded text disassembly for one function.",
        "parameters": {
            "function": {
                "description": "Function name or address.",
                "type": "string",
                "required": true
            },
            "max_instructions": {
                "description": "Maximum number of instructions to return.",
                "type": "integer",
                "minimum": 25,
                "maximum": 500
            }
        }
    },
    "callers": {
        "description": "Return callers of one function.",
        "parameters": {
            "function": {
                "description": "Function name or address.",
                "type": "string",
                "required": true
            }
        }
    },
    "callees": {
        "description": "Return callees of one function.",
        "parameters": {
            "function": {
                "description": "Function name or address.",
                "type": "string",
                "required": true
            }
        }
    },
    "string_xrefs": {
        "description": "Find strings and their cross-references.",
        "parameters": {
            "value": {
                "description": "String value to search.",
                "type": "string",
                "required": true
            }
        }
    },
    "import_xrefs": {
        "description": "Find imports and their cross-references.",
        "parameters": {
            "import_name": {
                "description": "Import name to search.",
                "type": "string",
                "required": true
            }
        }
    }
}
